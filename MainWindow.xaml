<Window x:Class="VehicleMeterSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Vehicle Meter Simulator"
        Height="600"
        Width="1000"
        MinHeight="540"
        MinWidth="860"
        Background="#050507"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="SpecLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8C8C88" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style x:Key="SpecValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ECECEA" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>
    </Window.Resources>

    <Grid Background="#050507">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="40,36,40,24"
                    HorizontalAlignment="Center">
            <TextBlock Text="Vehicle Meter Simulator"
                       Foreground="#F4F4F2"
                       FontSize="42"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />

            <TextBlock Text="Select Vehicle"
                       Foreground="#B8B8B5"
                       FontSize="20"
                       Margin="0,12,0,0"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="1"
              Margin="72,12,72,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,28,0"
                    Padding="28"
                    Background="#0B0B0E"
                    BorderBrush="#2B1010"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Vehicle"
                               Foreground="#D8D8D5"
                               FontSize="18"
                               FontWeight="SemiBold" />

                    <ComboBox x:Name="VehicleComboBox"
                              Margin="0,18,0,0"
                              Height="40"
                              DisplayMemberPath="Name"
                              SelectionChanged="VehicleComboBox_SelectionChanged" />

                    <Button Content="Open Meter Display"
                            Margin="0,36,0,0"
                            Height="44"
                            Background="#8E1717"
                            Foreground="#FFFFFF"
                            BorderBrush="#C22A2A"
                            FontWeight="SemiBold"
                            Click="OpenMeterButton_Click" />

                    <Button Content="Exit"
                            Margin="0,14,0,0"
                            Height="40"
                            Background="#151518"
                            Foreground="#D5D5D2"
                            BorderBrush="#333338"
                            Click="ExitButton_Click" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Padding="30"
                    Background="#09090C"
                    BorderBrush="#25252A"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Vehicle Specifications"
                               Foreground="#F0F0EE"
                               FontSize="22"
                               FontWeight="SemiBold" />

                    <Grid Grid.Row="1"
                          Margin="0,24,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Engine" Style="{StaticResource SpecLabelStyle}" />
                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="EngineTextBlock" Style="{StaticResource SpecValueStyle}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Power" Style="{StaticResource SpecLabelStyle}" />
                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PowerTextBlock" Style="{StaticResource SpecValueStyle}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Torque" Style="{StaticResource SpecLabelStyle}" />
                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="TorqueTextBlock" Style="{StaticResource SpecValueStyle}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Transmission" Style="{StaticResource SpecLabelStyle}" />
                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TransmissionTextBlock" Style="{StaticResource SpecValueStyle}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Drive Type" Style="{StaticResource SpecLabelStyle}" />
                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DriveTypeTextBlock" Style="{StaticResource SpecValueStyle}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                BorderBrush="#211010"
                BorderThickness="0,1,0,0"
                Padding="24,16">
            <TextBlock Text="Initial Vehicle: Lexus LFA"
                       Foreground="#8F8F8B"
                       FontSize="14"
                       HorizontalAlignment="Center" />
        </Border>
    </Grid>
</Window>
