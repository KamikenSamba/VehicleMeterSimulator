<UserControl x:Class="VehicleMeterSimulator.Views.Controls.NissanNoteE13.NoteE13InstrumentCluster"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:note="clr-namespace:VehicleMeterSimulator.Views.Controls.NissanNoteE13"
             Background="Transparent">
    <Viewbox Stretch="Uniform">
        <Canvas Width="1180" Height="610">
            <Canvas.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#020305" Offset="0.0" />
                    <GradientStop Color="#06080C" Offset="0.45" />
                    <GradientStop Color="#010102" Offset="1.0" />
                </LinearGradientBrush>
            </Canvas.Background>

            <Border Width="1180"
                    Height="610"
                    Background="#06070A"
                    BorderBrush="#16191E"
                    BorderThickness="1" />

            <Rectangle Canvas.Left="0"
                       Canvas.Top="0"
                       Width="1180"
                       Height="86"
                       Fill="#080A0D"
                       Opacity="0.94" />

            <note:NoteE13WarningLampLayer x:Name="WarningLampLayer"
                                          Canvas.Left="96"
                                          Canvas.Top="12" />

            <TextBlock Canvas.Left="472"
                       Canvas.Top="92"
                       x:Name="ClockText"
                       Text="12:00"
                       Foreground="#EEF2F0"
                       FontSize="25"
                       FontWeight="SemiBold" />
            <TextBlock Canvas.Left="635"
                       Canvas.Top="99"
                       x:Name="OutsideTempText"
                       Text="24°C"
                       Foreground="#E4E7E5"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Canvas.Left="560"
                       Canvas.Top="96"
                       Text="100"
                       Foreground="#D8D8D8"
                       FontSize="13"
                       FontWeight="Bold">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FF3333" BlurRadius="4" ShadowDepth="0" />
                </TextBlock.Effect>
            </TextBlock>

            <Canvas x:Name="PowerMeterCanvas"
                    Canvas.Left="70"
                    Canvas.Top="118"
                    Width="330"
                    Height="330">
                <Ellipse Width="250"
                         Height="250"
                         Canvas.Left="35"
                         Canvas.Top="28"
                         Fill="#07090B"
                         Stroke="#485159"
                         StrokeThickness="1.5" />
                <Ellipse Width="180"
                         Height="180"
                         Canvas.Left="70"
                         Canvas.Top="63"
                         Fill="#0D1114"
                         Stroke="#501B22"
                         StrokeThickness="8" />
                <Canvas x:Name="PowerTickCanvas" />
                <Path x:Name="PowerChargeArc"
                      Stroke="#2FBEE3"
                      StrokeThickness="4"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Opacity="0.85" />
                <Line x:Name="PowerNeedleLine"
                      X1="160"
                      Y1="153"
                      X2="160"
                      Y2="48"
                      Stroke="#E8F2F4"
                      StrokeThickness="3"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Triangle">
                    <Line.RenderTransform>
                        <RotateTransform x:Name="PowerNeedleRotateTransform"
                                         CenterX="160"
                                         CenterY="153" />
                    </Line.RenderTransform>
                </Line>
                <Border Canvas.Left="103"
                        Canvas.Top="102"
                        Width="114"
                        Height="66"
                        Background="#DDE4E8"
                        CornerRadius="8"
                        Opacity="0.95">
                    <Grid>
                        <Rectangle Width="74" Height="28" Fill="#0C1115" RadiusX="8" RadiusY="8" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <Ellipse Width="12" Height="12" Fill="#0C1115" HorizontalAlignment="Left" Margin="24,43,0,0" VerticalAlignment="Top" />
                        <Ellipse Width="12" Height="12" Fill="#0C1115" HorizontalAlignment="Right" Margin="0,43,24,0" VerticalAlignment="Top" />
                    </Grid>
                </Border>
                <TextBlock Canvas.Left="76" Canvas.Top="40" Text="0" Foreground="#EFF5F3" FontSize="15" FontWeight="Bold" />
                <TextBlock Canvas.Left="114" Canvas.Top="7" Text="20" Foreground="#EFF5F3" FontSize="15" FontWeight="Bold" />
                <TextBlock Canvas.Left="176" Canvas.Top="7" Text="40" Foreground="#EFF5F3" FontSize="15" FontWeight="Bold" />
                <TextBlock Canvas.Left="236" Canvas.Top="70" Text="60" Foreground="#EFF5F3" FontSize="15" FontWeight="Bold" />
                <TextBlock Canvas.Left="250" Canvas.Top="146" Text="80" Foreground="#EFF5F3" FontSize="15" FontWeight="Bold" />
                <TextBlock Canvas.Left="238" Canvas.Top="216" Text="100" Foreground="#EFF5F3" FontSize="15" FontWeight="Bold" />
                <TextBlock x:Name="PowerMeterValueText"
                           Canvas.Left="125"
                           Canvas.Top="212"
                           Width="70"
                           Text="0"
                           Foreground="#F4F8F8"
                           FontSize="31"
                           FontWeight="Bold"
                           TextAlignment="Center" />
                <TextBlock Canvas.Left="116" Canvas.Top="255" Text="POWER %" Foreground="#F4F8F8" FontSize="12" FontWeight="Bold" />
                <TextBlock x:Name="PowerMeterModeText"
                           Canvas.Left="104"
                           Canvas.Top="286"
                           Width="112"
                           Text="NEUTRAL"
                           Foreground="#879196"
                           FontSize="13"
                           FontWeight="Bold"
                           TextAlignment="Center" />
            </Canvas>

            <StackPanel Canvas.Left="512"
                        Canvas.Top="188"
                        Width="130">
                <TextBlock x:Name="ShiftPositionText"
                           Text="P"
                           Foreground="#F5F7F5"
                           FontSize="46"
                           FontWeight="SemiBold"
                           TextAlignment="Center" />
                <Border x:Name="DriveModeBadge"
                        Width="70"
                        Height="22"
                        BorderBrush="#AEB6B8"
                        BorderThickness="1"
                        CornerRadius="4"
                        HorizontalAlignment="Center">
                    <TextBlock x:Name="DriveModeText"
                               Text="ECO"
                               Foreground="#E8ECE9"
                               FontSize="12"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <TextBlock x:Name="PowerStateText"
                           Margin="0,22,0,0"
                           Text="POWER OFF"
                           Foreground="#5D6469"
                           FontSize="17"
                           FontWeight="Bold"
                           TextAlignment="Center" />
            </StackPanel>

            <Canvas Canvas.Left="700"
                    Canvas.Top="118"
                    Width="365"
                    Height="330">
                <TextBlock x:Name="SpeedText"
                           Canvas.Left="18"
                           Canvas.Top="16"
                           Width="230"
                           Text="0"
                           Foreground="#F7F8F6"
                           FontSize="122"
                           FontWeight="SemiBold"
                           TextAlignment="Right" />
                <TextBlock Canvas.Left="258"
                           Canvas.Top="116"
                           Text="km/h"
                           Foreground="#F2F2EF"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <Line X1="54" Y1="194" X2="280" Y2="194" Stroke="#D5DAD8" StrokeThickness="2" />
                <TextBlock x:Name="EstimatedRangeText" Canvas.Left="88" Canvas.Top="205" Text="RANGE 450 km" Foreground="#F0F2EF" FontSize="18" FontWeight="SemiBold" />
                <Line X1="54" Y1="238" X2="280" Y2="238" Stroke="#D5DAD8" StrokeThickness="2" />
                <TextBlock x:Name="OdometerText" Canvas.Left="88" Canvas.Top="244" Text="ODO 0 km" Foreground="#F0F2EF" FontSize="17" FontWeight="SemiBold" />
                <TextBlock x:Name="TripText" Canvas.Left="88" Canvas.Top="272" Text="TRIP 0.0 km" Foreground="#F0F2EF" FontSize="17" FontWeight="SemiBold" />

                <Canvas Canvas.Left="310" Canvas.Top="26" Width="42" Height="254">
                    <Line X1="20" Y1="10" X2="20" Y2="230" Stroke="#FFFFFF" StrokeThickness="2" />
                    <TextBlock Canvas.Left="30" Canvas.Top="0" Text="1" Foreground="#F2F2EF" FontSize="14" />
                    <TextBlock Canvas.Left="30" Canvas.Top="220" Text="0" Foreground="#F2F2EF" FontSize="14" />
                    <Rectangle Canvas.Left="4" Canvas.Top="28" Width="18" Height="182" Fill="#1C2024" />
                    <Rectangle x:Name="FuelLevelBar" Canvas.Left="4" Canvas.Top="74" Width="18" Height="136" Fill="#F4F5F2" />
                    <Rectangle Canvas.Left="4" Canvas.Top="202" Width="18" Height="8" Fill="#D82020" />
                    <TextBlock Canvas.Left="-4" Canvas.Top="118" Text="▸" Foreground="#F4F5F2" FontSize="18" />
                    <TextBlock Canvas.Left="-2" Canvas.Top="238" Text="FUEL" Foreground="#9FA7AA" FontSize="10" />
                </Canvas>
            </Canvas>

            <Border x:Name="PreviewPanel"
                    Canvas.Left="72"
                    Canvas.Top="112"
                    Width="360"
                    Height="330"
                    Background="#B0163450"
                    BorderBrush="#D0406375"
                    BorderThickness="2"
                    Visibility="Collapsed"
                    Padding="22">
                <StackPanel>
                    <TextBlock Text="CRUISE"
                               Foreground="#EAB4C2"
                               FontSize="22"
                               FontWeight="SemiBold"
                               TextAlignment="Center" />
                    <TextBlock Margin="0,70,0,0"
                               Text="State / Lamp Preview"
                               Foreground="#FFFFFF"
                               FontSize="24"
                               FontWeight="Bold"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="PreviewText"
                               Margin="0,34,0,0"
                               Foreground="#F8DDE4"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Canvas.Left="952"
                    Canvas.Top="454"
                    Width="184"
                    Height="88"
                    Background="#B005070A"
                    BorderBrush="#323A42"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="E13 AUDIO"
                               Foreground="#8E979B"
                               FontSize="10"
                               FontWeight="Bold" />
                    <DockPanel Grid.Row="1" Margin="0,6,0,0">
                        <TextBlock Text="TURN"
                                   Width="58"
                                   Foreground="#B8C0C2"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="TurnSignalAudioStatusText"
                                   Text="NO FILE"
                                   Foreground="#777F84"
                                   FontSize="11"
                                   FontWeight="Bold" />
                    </DockPanel>
                    <DockPanel Grid.Row="2" Margin="0,3,0,0">
                        <TextBlock Text="REVERSE"
                                   Width="58"
                                   Foreground="#B8C0C2"
                                   FontSize="11"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="ReverseAudioStatusText"
                                   Text="NO FILE"
                                   Foreground="#777F84"
                                   FontSize="11"
                                   FontWeight="Bold" />
                    </DockPanel>
                    <DockPanel Grid.Row="3" Margin="0,3,0,0">
                        <TextBlock Text="APPROACH"
                                   Width="58"
                                   Foreground="#B8C0C2"
                                   FontSize="10"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="ForwardApproachAudioStatusText"
                                   Text="NO FILE"
                                   Foreground="#777F84"
                                   FontSize="11"
                                   FontWeight="Bold" />
                    </DockPanel>
                </Grid>
            </Border>

            <Border Canvas.Left="208"
                    Canvas.Top="540"
                    Width="760"
                    Padding="10,7"
                    Background="#050608"
                    BorderBrush="#20242A"
                    BorderThickness="1">
                <TextBlock x:Name="SystemMessageText"
                           Text="Power OFF"
                           Foreground="#B8C0C2"
                           FontSize="16"
                           FontWeight="SemiBold"
                           TextAlignment="Center" />
            </Border>
        </Canvas>
    </Viewbox>
</UserControl>
