<UserControl x:Class="VehicleMeterSimulator.Views.Controls.LexusLfa.LfaWarningLampLayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="1180"
             Height="96"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="LampBorderStyle" TargetType="Border">
            <Setter Property="Width" Value="92" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="5,0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#08080A" />
            <Setter Property="BorderBrush" Value="#2A2A2E" />
        </Style>
        <Style x:Key="LampTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#333338" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="LeftTurnText"
                       Grid.Column="1"
                       Text="◀"
                       Foreground="#1A3323"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="TailLampText"
                       Grid.Column="2"
                       Text="TAIL"
                       Foreground="#282828"
                       FontSize="14"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="RightTurnText"
                       Grid.Column="3"
                       Text="▶"
                       Foreground="#1A3323"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>

        <UniformGrid Grid.Row="1"
                     Columns="9"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
            <Border x:Name="CheckLampBorder" Style="{StaticResource LampBorderStyle}">
                <TextBlock x:Name="CheckLampText" Text="CHECK" Style="{StaticResource LampTextStyle}" />
            </Border>
            <Border x:Name="AbsLampBorder" Style="{StaticResource LampBorderStyle}">
                <TextBlock x:Name="AbsLampText" Text="ABS" Style="{StaticResource LampTextStyle}" />
            </Border>
            <Border x:Name="OilLampBorder" Style="{StaticResource LampBorderStyle}">
                <TextBlock x:Name="OilLampText" Text="OIL" Style="{StaticResource LampTextStyle}" />
            </Border>
            <Border x:Name="BatteryLampBorder" Style="{StaticResource LampBorderStyle}">
                <TextBlock x:Name="BatteryLampText" Text="BATT" Style="{StaticResource LampTextStyle}" />
            </Border>
            <Border x:Name="BrakeLampBorder" Style="{StaticResource LampBorderStyle}">
                <TextBlock x:Name="BrakeLampText" Text="BRAKE" Style="{StaticResource LampTextStyle}" />
            </Border>
            <Border x:Name="VscLampBorder" Style="{StaticResource LampBorderStyle}">
                <TextBlock x:Name="VscLampText" Text="VSC" Style="{StaticResource LampTextStyle}" />
            </Border>
            <Border x:Name="TrcLampBorder" Style="{StaticResource LampBorderStyle}">
                <TextBlock x:Name="TrcLampText" Text="TRC" Style="{StaticResource LampTextStyle}" />
            </Border>
            <Border x:Name="HighBeamLampBorder" Style="{StaticResource LampBorderStyle}">
                <TextBlock x:Name="HighBeamLampText" Text="HIGH" Style="{StaticResource LampTextStyle}" />
            </Border>
            <Border x:Name="ShiftLampBorder" Style="{StaticResource LampBorderStyle}">
                <TextBlock x:Name="ShiftLampText" Text="SHIFT" Style="{StaticResource LampTextStyle}" />
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
