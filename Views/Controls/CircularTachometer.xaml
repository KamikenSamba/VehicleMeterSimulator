<UserControl x:Class="VehicleMeterSimulator.Views.Controls.CircularTachometer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="560"
             d:DesignWidth="560"
             Width="560"
             Height="560"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="TachNumberStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E9EEF2" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Width="560" Height="560">
        <Canvas x:Name="GaugeCanvas" Width="560" Height="560">
            <Ellipse x:Name="OuterRingEllipse"
                     Canvas.Left="20"
                     Canvas.Top="20"
                     Width="520"
                     Height="520"
                     Fill="#05070A"
                     Stroke="#32383D"
                     StrokeThickness="10" />

            <Ellipse x:Name="InnerGlowEllipse"
                     Canvas.Left="42"
                     Canvas.Top="42"
                     Width="476"
                     Height="476"
                     Fill="#080B10"
                     Stroke="#66808F"
                     StrokeThickness="2"
                     Opacity="0.65" />

            <Ellipse Canvas.Left="72"
                     Canvas.Top="72"
                     Width="416"
                     Height="416"
                     Fill="#020304"
                     Stroke="#1B252D"
                     StrokeThickness="1" />

            <Path x:Name="RedZoneArc"
                  Stroke="#8D1818"
                  StrokeThickness="18"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Opacity="0.65"
                  Data="M 474,392 A 224,224 0 0 1 392,474" />

            <Canvas x:Name="TachTickCanvas" Width="560" Height="560" />
            <Canvas x:Name="TachNumberCanvas" Width="560" Height="560" />

            <TextBlock x:Name="GaugeVehicleNameText"
                       Canvas.Left="130"
                       Canvas.Top="115"
                       Width="300"
                       Text=""
                       Foreground="#BFD7E6"
                       FontSize="15"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       Visibility="Collapsed" />

            <TextBlock x:Name="GaugeStyleText"
                       Canvas.Left="190"
                       Canvas.Top="135"
                       Width="180"
                       Text=""
                       Foreground="#86BBD8"
                       FontSize="12"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       Visibility="Collapsed" />

            <TextBlock Canvas.Left="220"
                       Canvas.Top="414"
                       Width="120"
                       Text="x1000 r/min"
                       Foreground="#9CA9B2"
                       FontSize="15"
                       FontWeight="SemiBold"
                       TextAlignment="Center" />

            <Line x:Name="NeedleLine"
                  X1="280"
                  Y1="280"
                  X2="280"
                  Y2="88"
                  Stroke="#EAF8FF"
                  StrokeThickness="5"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Triangle">
                <Line.RenderTransform>
                    <RotateTransform x:Name="NeedleRotateTransform"
                                     CenterX="280"
                                     CenterY="280"
                                     Angle="-150" />
                </Line.RenderTransform>
            </Line>

            <Ellipse Canvas.Left="264"
                     Canvas.Top="264"
                     Width="32"
                     Height="32"
                     Fill="#DCECF5"
                     Stroke="#52636D"
                     StrokeThickness="3" />
        </Canvas>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,26,0,0">
            <TextBlock x:Name="SpeedValueText"
                       Text="0"
                       Foreground="#F7FAFC"
                       FontSize="72"
                       FontWeight="Light"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />

            <TextBlock Text="km/h"
                       Foreground="#AAB8C2"
                       FontSize="18"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />

            <TextBlock x:Name="MeterModeText"
                       Text="ASG"
                       Foreground="#5F7684"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Margin="0,18,0,0"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />

            <TextBlock x:Name="GearValueText"
                       Text="N"
                       Foreground="#FFFFFF"
                       FontSize="68"
                       FontWeight="SemiBold"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />

            <TextBlock x:Name="RpmDigitalText"
                       Text="RPM: 0"
                       Foreground="#AAB8C2"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,6,0,0"
                       TextAlignment="Center"
                       HorizontalAlignment="Center" />

            <TextBlock x:Name="SelfCheckText"
                       Text="SELF CHECK"
                       Foreground="#FF5C5C"
                       FontSize="17"
                       FontWeight="SemiBold"
                       Margin="0,10,0,0"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed" />
        </StackPanel>
    </Grid>
</UserControl>
