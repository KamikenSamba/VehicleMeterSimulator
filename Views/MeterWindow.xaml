<Window x:Class="VehicleMeterSimulator.Views.MeterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:VehicleMeterSimulator.Views.Controls"
        xmlns:lfa="clr-namespace:VehicleMeterSimulator.Views.Controls.LexusLfa"
        xmlns:note="clr-namespace:VehicleMeterSimulator.Views.Controls.NissanNoteE13"
        mc:Ignorable="d"
        Title="Meter Display"
        Height="860"
        Width="1300"
        MinHeight="780"
        MinWidth="1100"
        Background="#030305"
        Focusable="True"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ControlHintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A6A6A1" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ControlKeyStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F0F0EA" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,10,4" />
            <Setter Property="MinWidth" Value="42" />
        </Style>

        <Style x:Key="ControlGroupTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#DC3636" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="StatusLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8F8F8A" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Background="#030305">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="42,30,42,10">
            <Button Content="Back to Vehicle Selection"
                    DockPanel.Dock="Right"
                    Width="210"
                    Height="38"
                    Background="#141417"
                    Foreground="#E6E6E3"
                    BorderBrush="#38383C"
                    Click="BackButton_Click" />

            <TextBlock x:Name="VehicleNameTextBlock"
                       Foreground="#F2F2EF"
                       FontSize="30"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <TextBlock x:Name="TransmissionTextBlock"
                       Margin="18,8,0,0"
                       Foreground="#8F9BA3"
                       FontSize="15"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
        </DockPanel>

        <Grid Grid.Row="1"
              Margin="40,8,40,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    x:Name="PowertrainStatusPanel"
                    Margin="0,40,26,40"
                    Padding="22"
                    Background="#08080B"
                    BorderBrush="#242428"
                    BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="POWERTRAIN" Style="{StaticResource StatusLabelStyle}" />

                    <Border x:Name="IgnitionStatusBorder"
                            Margin="0,18,0,0"
                            Padding="18,12"
                            BorderBrush="#303034"
                            BorderThickness="1"
                            Background="#0D0D10">
                        <TextBlock x:Name="IgnitionStatusText"
                                   Text="Ignition: OFF"
                                   Foreground="#8F8F8A"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <Border x:Name="EngineStatusBorder"
                            Margin="0,14,0,0"
                            Padding="18,12"
                            BorderBrush="#303034"
                            BorderThickness="1"
                            Background="#0D0D10">
                        <TextBlock x:Name="EngineStatusText"
                                   Text="Engine: OFF"
                                   Foreground="#8F8F8A"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <Border x:Name="DriveModeStatusBorder"
                            Margin="0,22,0,0"
                            Padding="18,12"
                            BorderBrush="#303034"
                            BorderThickness="1"
                            Background="#0D0D10">
                        <StackPanel>
                            <TextBlock Text="SIMULATION MODE"
                                       Foreground="#777772"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="DriveModeText"
                                       Text="NORMAL"
                                       Foreground="#E6E6E3"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="TransmissionModeStatusBorder"
                            Margin="0,14,0,0"
                            Padding="18,12"
                            BorderBrush="#303034"
                            BorderThickness="1"
                            Background="#0D0D10">
                        <StackPanel>
                            <TextBlock Text="SIMULATION TRANSMISSION"
                                       Foreground="#777772"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="TransmissionModeText"
                                       Text="MANUAL"
                                       Foreground="#E6E6E3"
                                       FontSize="23"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1"
                  x:Name="GenericMeterPanel"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:IndicatorPanel x:Name="MainIndicatorPanel"
                                         Grid.Row="0"
                                         Margin="0,0,0,8" />

                <controls:CircularTachometer x:Name="MainTachometer"
                                             Grid.Row="1" />
            </Grid>

            <Border Grid.Column="2"
                    x:Name="InputStatusPanel"
                    Margin="26,40,0,40"
                    Padding="22"
                    Background="#08080B"
                    BorderBrush="#242428"
                    BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="INPUTS" Style="{StaticResource StatusLabelStyle}" />

                    <Border x:Name="ThrottleStatusBorder"
                            Margin="0,18,0,0"
                            Padding="18,12"
                            BorderBrush="#303034"
                            BorderThickness="1"
                            Background="#0D0D10">
                        <TextBlock x:Name="ThrottleText"
                                   Text="Throttle: 0%"
                                   Foreground="#BDBDB8"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <Border x:Name="BrakeStatusBorder"
                            Margin="0,14,0,0"
                            Padding="18,12"
                            BorderBrush="#303034"
                            BorderThickness="1"
                            Background="#0D0D10">
                        <TextBlock x:Name="BrakeText"
                                   Text="Brake: 0%"
                                   Foreground="#BDBDB8"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <Border x:Name="ParkingBrakeStatusBorder"
                            Margin="0,14,0,0"
                            Padding="18,12"
                            BorderBrush="#303034"
                            BorderThickness="1"
                            Background="#0D0D10">
                        <TextBlock x:Name="ParkingBrakeStatusText"
                                   Text="Parking Brake: ON"
                                   Foreground="#BDBDB8"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <Border x:Name="AudioStatusBorder"
                            Margin="0,14,0,0"
                            Padding="18,12"
                            BorderBrush="#303034"
                            BorderThickness="1"
                            Background="#0D0D10">
                        <TextBlock x:Name="AudioStatusText"
                                   Text="Audio: No Files"
                                   Foreground="#8F8F8A"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <Border x:Name="MasterVolumeStatusBorder"
                            Margin="0,14,0,0"
                            Padding="18,12"
                            BorderBrush="#303034"
                            BorderThickness="1"
                            Background="#0D0D10">
                        <StackPanel>
                            <TextBlock Text="MASTER VOLUME"
                                       Foreground="#777772"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="MasterVolumeText"
                                       Text="75%"
                                       Foreground="#BDBDB8"
                                       FontSize="19"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="EngineAudioStatusBorder"
                            Margin="0,14,0,0"
                            Padding="18,12"
                            BorderBrush="#303034"
                            BorderThickness="1"
                            Background="#0D0D10">
                        <StackPanel>
                            <TextBlock Text="ENGINE SOUND"
                                       Foreground="#777772"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Name="EngineAudioStatusText"
                                       Text="NO LOOP FILE"
                                       Foreground="#8F8F8A"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,30,0,0"
                            Padding="18"
                            Background="#050507"
                            BorderBrush="#1A1A1E"
                            BorderThickness="1">
                        <TextBlock x:Name="SystemMessageText"
                                   Text="Press I to switch ignition on"
                                   Foreground="#A8A8A3"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Border>

            <lfa:LfaInstrumentCluster x:Name="LfaInstrumentCluster"
                                      Grid.ColumnSpan="3"
                                      Visibility="Collapsed"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch" />

            <note:NoteE13InstrumentCluster x:Name="NoteE13InstrumentCluster"
                                           Grid.ColumnSpan="3"
                                           Visibility="Collapsed"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch" />

            <controls:AudioTuningPanel x:Name="AudioTuningPanel"
                                       Grid.Column="2"
                                       Margin="0,0,0,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Top"
                                       Visibility="Collapsed" />

            <Border x:Name="AudioDebugPanel"
                    Grid.Column="1"
                    Width="380"
                    Padding="16"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Visibility="Collapsed"
                    Background="#DD050507"
                    BorderBrush="#323238"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="AUDIO DEBUG"
                               Foreground="#DC3636"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="AudioDebugText"
                               Margin="0,8,0,0"
                               Foreground="#D0D0CA"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                BorderBrush="#17171A"
                BorderThickness="0,1,0,0"
                Padding="24,14">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Border x:Name="CombustionKeyGuidePanel"
                        Width="560"
                        Margin="0,0,12,0"
                        Padding="14,10"
                        Background="#08080B"
                        BorderBrush="#242428"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="DRIVING CONTROLS" Style="{StaticResource ControlGroupTitleStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="I" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Ignition / Power" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="S" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Engine Start / Stop" Style="{StaticResource ControlHintStyle}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="A" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Accelerator" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="Z" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Brake" Style="{StaticResource ControlHintStyle}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Up / Down" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Shift / Drive Select" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="R / P" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="Reverse / Parking Brake" Style="{StaticResource ControlHintStyle}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="D / T" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Drive / Transmission Mode" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="M" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="Mute Audio" Style="{StaticResource ControlHintStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="LfaKeyGuidePanel"
                        Width="390"
                        Margin="0,0,12,0"
                        Padding="14,10"
                        Background="#08080B"
                        BorderBrush="#242428"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="AUDIO / LFA DISPLAY" Style="{StaticResource ControlGroupTitleStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="+ / -" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Master Volume" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="V / F2" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Audio Debug / Tuning" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Q / E / H" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Turn Signals / Hazard" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="L / B" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Tail / High Beam (LFA)" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="F3 / F4" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Lamp Test / LFA Menu" Style="{StaticResource ControlHintStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="NoteKeyGuidePanel"
                        Width="760"
                        Padding="14,10"
                        Background="#08080B"
                        BorderBrush="#242428"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="NISSAN NOTE e-POWER E13" Style="{StaticResource ControlGroupTitleStyle}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="I" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Power Switch / READY" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="A / Z" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Accelerator / Brake" Style="{StaticResource ControlHintStyle}" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="P/R/N/D/B" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Shift Position" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="K" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Electric Parking Brake" Style="{StaticResource ControlHintStyle}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="O" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="Auto Brake Hold" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="C" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="NORMAL / SPORT / ECO" Style="{StaticResource ControlHintStyle}" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="G / Y" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="Charge / Manner Mode" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="L / U" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="Tail / High Beam" Style="{StaticResource ControlHintStyle}" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Q/E/H" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="Turn / Hazard" Style="{StaticResource ControlHintStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="F3" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="4" Grid.Column="3" Text="State Preview Panel" Style="{StaticResource ControlHintStyle}" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="M" Style="{StaticResource ControlKeyStyle}" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="Mute Audio" Style="{StaticResource ControlHintStyle}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
